# Docker Compose deployment settings
HX_RESUME_PORT=8080
HX_RESUME_USERNAME=admin

# Required: at least 12 characters. Do not commit the real .env file.
HX_RESUME_PASSWORD=replace-with-a-long-password

# Required: generate with `openssl rand -hex 32`.
HX_RESUME_SESSION_SECRET=replace-with-at-least-32-random-characters

# Set to true only when the browser accesses HX-Resume through HTTPS.
HX_RESUME_COOKIE_SECURE=false

# Login duration in seconds (default: 12 hours).
HX_RESUME_SESSION_MAX_AGE=43200
